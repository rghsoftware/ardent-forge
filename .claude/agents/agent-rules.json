  "notes": {
    "enforcement_types": {
      "suggest": "Agent suggestion appears but doesn't block execution",
      "block": "Requires agent to be used before proceeding (guardrail)",
      "warn": "Shows warning but allows proceeding"
    },
    "priority_levels": {
      "critical": "Highest - Always trigger when matched (e.g., master-orchestrator for complex planning)",
      "high": "Important - Trigger for most matches (e.g., frontend, backend, testing, security)",
      "medium": "Moderate - Trigger for clear matches (e.g., research, mobile development, n8n)",
      "low": "Optional - Trigger only for explicit matches (e.g., session-librarian)"
    },
    "common_invocation_patterns": {
      "spawn": "spawn the X to...",
      "invoke": "invoke the X with...",
      "use": "we can use the X agent for that",
      "dispatch": "dispatch agents in parallel",
      "launch": "launch a X agent",
      "request": "request a X or a series of sub-agents",
      "send": "send another subagent into...",
      "execute": "execute a X agent and a Y agent in parallel"
    },
    "agent_overview": {
