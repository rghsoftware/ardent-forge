{$SITE_URL} {
    # Supabase API routes -- proxied through Kong gateway
    handle /rest/v1/* {
        reverse_proxy kong:8000
    }

    handle /auth/v1/* {
        reverse_proxy kong:8000
    }

    handle /realtime/v1/* {
        reverse_proxy kong:8000
    }

    # Supabase Studio admin dashboard (when enabled)
    handle /studio/* {
        uri strip_prefix /studio
        reverse_proxy studio:3000
    }

    # Instance discovery endpoint
    handle /.well-known/ardent-forge.json {
        header Content-Type application/json
        header Cache-Control "public, max-age=3600"
        respond `{"version":"1","supabase_url":"{$SITE_URL}","supabase_publishable_key":"{$ANON_KEY}"}`
    }

    # Web app -- catch-all for the SPA
    handle {
        reverse_proxy web:80
    }
}
